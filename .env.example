# ──────────────────────────────────────────────────────────────────────────
# MerchFine — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────

# ── MLflow ────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_EXPERIMENT_NAME=merchfine

# ── Ollama ────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434

# ── LiteLLM ───────────────────────────────────────────────────────────────
LITELLM_HOST=http://127.0.0.1:4000
LITELLM_MASTER_KEY=sk-merchfine-local

# ── Redis (optional — falls back to in-memory cache) ─────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── Langfuse (optional — tracing disabled if not set) ─────────────────────
LANGFUSE_HOST=http://127.0.0.1:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Paths ─────────────────────────────────────────────────────────────────
MERCHFINE_CONFIG_DIR=./config
MERCHFINE_DATA_DIR=./data
MERCHFINE_OUTPUTS_DIR=./outputs
MERCHFINE_LOG_LEVEL=INFO
MERCHFINE_LOG_FORMAT=json

# ── GPU ───────────────────────────────────────────────────────────────────
CUDA_VISIBLE_DEVICES=0
