# ──────────────────────────────────────────────────────────────────────────
# MerchFine — Environment Configuration Template
# Copy to .env and fill in your values: cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ REQUIRED FOR FULL FUNCTIONALITY                                        │
# └─────────────────────────────────────────────────────────────────────────┘

# OpenAI API Key — used by RAGAS & DeepEval for LLM-as-judge metrics
# Not needed for local-only Ollama inference or training
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Hugging Face Token — needed for gated models (Gemma, Llama, etc.)
# Generate at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ LOCAL SERVICES (defaults work out of the box)                          │
# └─────────────────────────────────────────────────────────────────────────┘

# MLflow — experiment tracking & model registry
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_EXPERIMENT_NAME=merchfine

# Ollama — local LLM inference
OLLAMA_HOST=http://127.0.0.1:11434

# LiteLLM — unified LLM gateway
LITELLM_HOST=http://127.0.0.1:4000
LITELLM_MASTER_KEY=sk-merchfine-local

# Redis — response caching (optional, falls back to in-memory)
REDIS_URL=redis://127.0.0.1:6379/0

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ OBSERVABILITY (optional — disabled if keys are empty)                  │
# └─────────────────────────────────────────────────────────────────────────┘

# Langfuse — LLM tracing & analytics
LANGFUSE_HOST=http://127.0.0.1:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Weights & Biases — experiment tracking alternative
WANDB_API_KEY=
WANDB_PROJECT=merchfine
WANDB_ENTITY=

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ PATHS & SYSTEM                                                         │
# └─────────────────────────────────────────────────────────────────────────┘

MERCHFINE_CONFIG_DIR=./config
MERCHFINE_DATA_DIR=./data
MERCHFINE_OUTPUTS_DIR=./outputs
MERCHFINE_MODEL_PATH=
MERCHFINE_LOG_LEVEL=INFO
MERCHFINE_LOG_FORMAT=json

# GPU
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Inference Server
MERCHFINE_INFERENCE_HOST=127.0.0.1
MERCHFINE_INFERENCE_PORT=8000

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ EVALUATION (offline-first, uses OPENAI_API_KEY if set)                 │
# └─────────────────────────────────────────────────────────────────────────┘

# For fully local eval (no OpenAI), point judges to Ollama:
DEEPEVAL_LLM_MODEL=ollama/merchfine:q4_k_m
DEEPEVAL_LLM_API_BASE=http://127.0.0.1:11434
RAGAS_LLM_MODEL=ollama/merchfine:q4_k_m
RAGAS_LLM_API_BASE=http://127.0.0.1:11434
